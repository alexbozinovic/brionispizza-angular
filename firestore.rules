rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'bMjGnyeYmLe32GlIQbhBCkdPprm1';
    }

    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}